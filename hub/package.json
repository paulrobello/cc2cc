{
  "name": "@cc2cc/hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "bun --watch --env-file=../.env src/index.ts",
    "start": "bun --env-file=../.env src/index.ts",
    "build": "echo 'hub: no separate build step (bun runs TS directly)'",
    "test": "bun test tests/",
    "lint": "bunx biome lint ./src ./tests",
    "fmt": "bunx biome format --write ./src ./tests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cc2cc/shared": "workspace:*",
    "cron-parser": "4",
    "hono": "^4.12.8",
    "ioredis": "^5.7.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/bun": "^1.3.11",
    "typescript": "^5.9.3"
  }
}
