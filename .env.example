# Shared API key — must match across hub, plugin, and dashboard
CC2CC_HUB_API_KEY=change-me-before-use

# Hub
CC2CC_HUB_PORT=3100
CC2CC_REDIS_PASSWORD=changeme
CC2CC_REDIS_URL=redis://:changeme@localhost:6379

# Dashboard (baked in at build time for Docker; set at runtime for local dev)
NEXT_PUBLIC_CC2CC_HUB_WS_URL=ws://localhost:3100
NEXT_PUBLIC_CC2CC_HUB_API_KEY=change-me-before-use

# Plugin
CC2CC_HUB_URL=ws://192.168.1.10:3100
CC2CC_API_KEY=change-me-before-use
CC2CC_USERNAME=
CC2CC_HOST=
CC2CC_PROJECT=

# LAN IP for docker-compose (set to your machine's LAN IP for multi-device access)
CC2CC_HOST_LAN_IP=localhost
