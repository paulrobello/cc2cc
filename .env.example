# Shared API key — must match across hub, plugin, and dashboard.
# Generate a strong random value, e.g.: openssl rand -hex 32
# SECURITY: Never commit a real key. This file must only contain placeholder values.
CC2CC_HUB_API_KEY=your-api-key-here

# Hub
CC2CC_HUB_PORT=3100
# SECURITY: Change the Redis password before connecting to any network.
# For local dev (non-Docker): redis://:your-redis-password-here@localhost:6379
# For Docker (hub connects to 'redis' service): redis://:your-redis-password-here@redis:6379
CC2CC_REDIS_PASSWORD=your-redis-password-here
CC2CC_REDIS_URL=redis://:your-redis-password-here@localhost:6379

# Dashboard (baked in at build time for Docker; set at runtime for local dev)
# SECURITY: See README Security section — dashboard must NEVER be internet-exposed.
NEXT_PUBLIC_CC2CC_HUB_WS_URL=ws://localhost:3100
NEXT_PUBLIC_CC2CC_HUB_API_KEY=your-api-key-here

# Plugin
# Set CC2CC_HUB_URL to the LAN IP of your hub host (e.g. ws://192.168.1.100:3100)
CC2CC_HUB_URL=ws://192.168.1.100:3100
CC2CC_API_KEY=your-api-key-here
CC2CC_USERNAME=
CC2CC_HOST=
CC2CC_PROJECT=

# LAN IP for docker-compose (set to your machine's LAN IP for multi-device access)
CC2CC_HOST_LAN_IP=localhost
